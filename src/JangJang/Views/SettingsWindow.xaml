<Window x:Class="JangJang.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="장장 설정" Width="340" Height="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <StackPanel Margin="16">
        <TextBlock Text="감시 대상 프로그램" FontWeight="Bold" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <TextBox x:Name="TargetProcessBox" Width="160" Margin="0,0,8,0"/>
            <Button Content="실행 중 프로그램에서 선택..." Click="OnSelectProcessClick" Padding="4,2"/>
        </StackPanel>

        <Separator Margin="0,12,0,12"/>

        <TextBlock Text="유휴 시간 설정" FontWeight="Bold" FontSize="14"/>
        <ComboBox x:Name="PresetCombo" Margin="0,4,0,0" SelectionChanged="OnPresetChanged"/>
        <StackPanel x:Name="CustomPanel" Orientation="Horizontal" Visibility="Collapsed" Margin="0,4,0,0">
            <TextBlock Text="사용자 지정 (분):" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="CustomMinutesBox" Width="60" Text="10"/>
        </StackPanel>

        <Separator Margin="0,12,0,12"/>

        <TextBlock Text="펫 이미지" FontWeight="Bold" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <Border BorderBrush="Gray" BorderThickness="1" Width="64" Height="64" Margin="0,0,8,0">
                <Image x:Name="PreviewImage" Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <Button Content="이미지 선택..." Click="OnSelectImageClick" Padding="8,4"/>
                <Button Content="기본 이미지로" Click="OnResetImageClick" Padding="8,4" Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>
        <TextBlock x:Name="ImagePathText" Text="" FontSize="10" Foreground="Gray" Margin="0,4,0,0"
                   TextTrimming="CharacterEllipsis"/>

        <Separator Margin="0,12,0,12"/>

        <TextBlock Text="펫 크기" FontWeight="Bold" FontSize="14"/>
        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
            <Slider x:Name="SizeSlider" Minimum="0.5" Maximum="5.0" Width="180"
                    TickFrequency="0.1" IsSnapToTickEnabled="True" Value="1.0"/>
            <TextBlock Text="{Binding Value, ElementName=SizeSlider, StringFormat={}{0:F1}x}"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <Separator Margin="0,12,0,12"/>

        <CheckBox x:Name="GrowCheck" Content="화나면 점점 커지기" Margin="0,0,0,4"/>
        <StackPanel x:Name="GrowPanel" Orientation="Horizontal" Margin="16,0,0,0">
            <TextBlock Text="최대 배율:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Slider x:Name="GrowSlider" Minimum="1.5" Maximum="5.0" Width="120"
                    TickFrequency="0.5" IsSnapToTickEnabled="True" Value="2.0"/>
            <TextBlock Text="{Binding Value, ElementName=GrowSlider, StringFormat={}{0:F1}x}"
                       VerticalAlignment="Center" Margin="8,0,0,0"/>
        </StackPanel>

        <Separator Margin="0,12,0,12"/>

        <Button Content="저장" Width="80" HorizontalAlignment="Right"
                Click="OnSaveClick" Padding="8,4"/>
    </StackPanel>
</Window>
