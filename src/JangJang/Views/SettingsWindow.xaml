<Window x:Class="JangJang.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="자캐 타이머 설정" Width="440" Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="20">

                <TextBlock Text="설정" Style="{StaticResource PageTitle}" Margin="0,0,0,16"/>

                <!-- ─── Card: 일반 ─── -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="일반" Style="{StaticResource SectionHeader}"/>
                        <CheckBox x:Name="AutoStartCheck" Content="Windows 시작 시 자동 실행" Margin="0,0,0,8"/>
                        <CheckBox x:Name="NoRestCheck" Content="휴식은 허락하지 않는다" Margin="0,0,0,8"/>
                        <CheckBox x:Name="DebugModeCheck" Content="디버그 모드 (파이프라인 모니터)"
                                  Checked="OnDebugModeChanged" Unchecked="OnDebugModeChanged"/>
                    </StackPanel>
                </Border>

                <!-- ─── Card: 자캐 페르소나 (Progressive Disclosure) ─── -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="자캐 페르소나" Style="{StaticResource SectionHeader}" Margin="0"/>
                            <Border Background="{StaticResource WarningLightBrush}"
                                    CornerRadius="4" Padding="6,2" Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="실험적" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource WarningTextBrush}"/>
                            </Border>
                        </StackPanel>

                        <CheckBox x:Name="PersonaEnabledCheck" Content="페르소나 모드 활성화" Margin="0,0,0,4"/>

                        <!-- Hint when persona is OFF -->
                        <TextBlock x:Name="PersonaOffHint"
                                   Text="활성화하면 자캐 페르소나 관련 설정이 나타납니다."
                                   Style="{StaticResource CaptionText}" Margin="26,0,0,0"/>

                        <!-- Detail panel: ONLY visible when persona is ON -->
                        <StackPanel x:Name="PersonaDetailPanel" Visibility="Collapsed" Margin="0,8,0,0">

                            <!-- Persona status indicator -->
                            <Border x:Name="PersonaStatusBadge" CornerRadius="6" Padding="10,6"
                                    Margin="0,0,0,8">
                                <TextBlock x:Name="PersonaStatusText" FontSize="11"/>
                            </Border>

                            <Button Content="자캐 페르소나 편집..." Click="OnEditPersonaClick"
                                    HorizontalAlignment="Left" Margin="0,0,0,4"/>
                            <TextBlock Style="{StaticResource CaptionText}"
                                       Text="변경은 재시작 후 적용됩니다."/>

                            <Separator Margin="0,12,0,12"/>

                            <!-- API settings — collapsible -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Button x:Name="ToggleApiBtn" Content="▶ 대사 생성 API 설정"
                                        Click="OnToggleApiSettings"
                                        Style="{StaticResource GhostButton}" FontSize="11"
                                        HorizontalAlignment="Left"/>
                                <TextBlock x:Name="ApiStatusIndicator" FontSize="10"
                                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>

                            <StackPanel x:Name="ApiSettingsPanel" Visibility="Collapsed">
                                <!-- API key + link on same row -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="API 키" Style="{StaticResource LabelText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <PasswordBox Grid.Column="1" x:Name="ApiKeyMasked" FontSize="11"/>
                                    <TextBox Grid.Column="1" x:Name="ApiKeyVisible" FontSize="11" Visibility="Collapsed"/>
                                    <Button Grid.Column="2" x:Name="ApiKeyToggleBtn" Content="표시"
                                            Click="OnToggleApiKeyClick" Margin="6,0,0,0" FontSize="11" Padding="8,5"/>
                                    <Button Grid.Column="3" Content="발급 →"
                                            Click="OnOpenAiStudioSettingsClick"
                                            Style="{StaticResource GhostButton}" Margin="2,0,0,0" FontSize="11"/>
                                </Grid>

                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="모델" Style="{StaticResource LabelText}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <ComboBox Grid.Column="1" x:Name="ModelCombo" FontSize="11"/>
                                    <Button Grid.Column="2" Content="검색"
                                            Click="OnDiscoverModelsClick" Margin="6,0,0,0" FontSize="11" Padding="8,5"/>
                                </Grid>

                                <Button Content="연결 테스트" Click="OnTestApiKeyClick"
                                        Style="{StaticResource GhostButton}" FontSize="11"
                                        HorizontalAlignment="Left" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Card: 감시 대상 ─── -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="감시 대상 프로그램" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="TargetProcessBox"/>
                            <Button Grid.Column="1" Content="목록에서 선택..." Click="OnSelectProcessClick"
                                    Margin="8,0,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Card: 경계 시간 ─── -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="경계 시간 설정" Style="{StaticResource SectionHeader}"/>
                        <ComboBox x:Name="PresetCombo" SelectionChanged="OnPresetChanged"/>
                        <StackPanel x:Name="CustomPanel" Orientation="Horizontal"
                                    Visibility="Collapsed" Margin="0,8,0,0">
                            <TextBlock Text="사용자 지정 (분):" Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="CustomMinutesBox" Width="70" Text="10"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Card: 이미지 (accordion) — visible when persona OFF ─── -->
                <StackPanel x:Name="ImageSettingsPanel">
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="이미지" Style="{StaticResource SectionHeader}"/>

                            <!-- Default image: always visible -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="6" Width="56" Height="56" Margin="0,0,10,0">
                                    <Image x:Name="PreviewDefault" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="기본 이미지" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="선택" Click="OnSelectDefaultImage" FontSize="11" Padding="8,4"/>
                                        <Button Content="초기화" Click="OnResetDefaultImage" FontSize="11" Padding="6,4"
                                                Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>

                            <!-- Toggle for state-specific images -->
                            <Button x:Name="ToggleImagesBtn" Content="▶ 상태별 이미지 펼치기"
                                    Click="OnToggleStateImages"
                                    Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Left" Margin="0,6,0,0" FontSize="11"/>

                            <!-- Collapsible state images -->
                            <StackPanel x:Name="StateImagePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 작업 중 -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,10">
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,3">
                                            <Image x:Name="PreviewHappy" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <TextBlock Text="작업 중" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="선택" Click="OnSelectHappyImage" FontSize="10" Padding="5,2"/>
                                            <Button Content="초기화" Click="OnResetHappyImage" FontSize="10" Padding="4,2"
                                                    Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 경계 -->
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="6,0,0,10">
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,3">
                                            <Image x:Name="PreviewIdle" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <TextBlock Text="경계" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="선택" Click="OnSelectIdleImage" FontSize="10" Padding="5,2"/>
                                            <Button Content="초기화" Click="OnResetIdleImage" FontSize="10" Padding="4,2"
                                                    Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 화남 -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,6,10">
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,3">
                                            <Image x:Name="PreviewAnnoyed" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <TextBlock Text="화남" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="선택" Click="OnSelectAnnoyedImage" FontSize="10" Padding="5,2"/>
                                            <Button Content="초기화" Click="OnResetAnnoyedImage" FontSize="10" Padding="4,2"
                                                    Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 수면 -->
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="6,0,0,10">
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,3">
                                            <Image x:Name="PreviewSleeping" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <TextBlock Text="수면" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="선택" Click="OnSelectSleepingImage" FontSize="10" Padding="5,2"/>
                                            <Button Content="초기화" Click="OnResetSleepingImage" FontSize="10" Padding="4,2"
                                                    Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 대기 -->
                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,6,0">
                                        <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                CornerRadius="6" Width="48" Height="48" HorizontalAlignment="Left" Margin="0,0,0,3">
                                            <Grid>
                                                <TextBlock x:Name="WakeUpPlaceholder" Text="?" FontSize="20" FontWeight="Bold"
                                                           Foreground="{StaticResource TextMutedBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Image x:Name="PreviewWakeUp" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="대기" FontWeight="SemiBold" FontSize="10" Margin="0,0,0,2"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="선택" Click="OnSelectWakeUpImage" FontSize="10" Padding="5,2"/>
                                            <Button Content="초기화" Click="OnResetWakeUpImage" FontSize="10" Padding="4,2"
                                                    Style="{StaticResource GhostButton}" Margin="2,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <TextBlock Style="{StaticResource CaptionText}" Margin="0,6,0,0"
                                       Text="상태별 이미지 미설정 시 기본 이미지가 사용됩니다."/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Note when images are hidden (persona mode ON) -->
                <Border x:Name="ImageHiddenNote" Visibility="Collapsed" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="이미지" Style="{StaticResource SectionHeader}"/>
                        <TextBlock Style="{StaticResource CaptionText}"
                                   Text="페르소나 모드에서는 페르소나 초상화가 사용되므로 이미지 설정이 비활성화됩니다."/>
                    </StackPanel>
                </Border>

                <!-- ─── Card: 크기 & 성장 ─── -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="크기" Style="{StaticResource SectionHeader}"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" x:Name="SizeSlider" Minimum="0.5" Maximum="5.0"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" Value="1.0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Value, ElementName=SizeSlider, StringFormat={}{0:F1}x}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>

                        <Separator Margin="0,8,0,8"/>

                        <CheckBox x:Name="GrowCheck" Content="화나면 점점 커지기" Margin="0,0,0,8"/>
                        <Grid Margin="20,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="최대 배율" Style="{StaticResource LabelText}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Grid.Column="1" x:Name="GrowSlider" Minimum="1.5" Maximum="5.0"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True" Value="2.0"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Value, ElementName=GrowSlider, StringFormat={}{0:F1}x}"
                                       VerticalAlignment="Center" Margin="12,0,0,0"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Save Button -->
                <Button Content="저장" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Stretch"
                        Click="OnSaveClick" Margin="0,4,0,8"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
