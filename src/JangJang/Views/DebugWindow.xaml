<Window x:Class="JangJang.Views.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="파이프라인 모니터" Width="520" Height="600"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{StaticResource BackgroundBrush}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="파이프라인 모니터" Style="{StaticResource PageTitle}" FontSize="16"/>
            <TextBlock x:Name="EntryCountText" Text=" — 0건"
                       Style="{StaticResource LabelText}" VerticalAlignment="Bottom" Margin="8,0,0,4"/>
        </StackPanel>

        <!-- Entry list -->
        <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="LogPanel"/>
        </ScrollViewer>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="지우기" Click="OnClearClick" Padding="12,5"/>
            <CheckBox x:Name="AutoScrollCheck" Content="자동 스크롤" IsChecked="True"
                      Margin="12,0,0,0" VerticalAlignment="Center"/>
            <CheckBox x:Name="TopmostCheck" Content="항상 위"
                      Checked="OnTopmostChanged" Unchecked="OnTopmostChanged"
                      Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
