<Window x:Class="JangJang.Views.Persona.PersonaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="자캐 페르소나 편집" Width="460" Height="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. 이름 + 초상화 -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="페르소나" FontWeight="Bold" FontSize="14"/>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Border BorderBrush="Gray" BorderThickness="1" Width="80" Height="80" Margin="0,0,12,0">
                    <Grid>
                        <TextBlock x:Name="PortraitPlaceholder" Text="?" FontSize="36" FontWeight="Bold"
                                   Foreground="Gray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="PreviewPortrait" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Grid>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="이름" FontSize="11" Foreground="Gray"/>
                    <TextBox x:Name="NameBox" Width="240" Margin="0,2,0,6"
                             TextChanged="OnAnyInputChanged"/>
                    <TextBlock Text="초상화 (1장, 필수)" FontSize="11" Foreground="Gray"/>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Button Content="선택..." Click="OnSelectPortraitClick" Padding="8,2" Margin="0,0,4,0"/>
                        <Button Content="제거" Click="OnClearPortraitClick" Padding="8,2"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <Separator Grid.Row="1" Margin="0,12,0,12"/>

        <!-- 2. 씨앗 대사 리스트 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <TextBlock Text="씨앗 대사" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock x:Name="SeedCountText" Text="(0개)" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock Text="— 최소 1개 필요 (권장 5개 이상)" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>

            <ListBox Grid.Row="1" x:Name="SeedListBox" Margin="0,6,0,6"
                     SelectionChanged="OnSeedSelectionChanged"
                     HorizontalContentAlignment="Stretch"
                     DisplayMemberPath="Text"/>

            <!-- 편집 패널 -->
            <Grid Grid.Row="2" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="대사" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="0,0,8,4"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="DialogueBox" Margin="0,0,0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="상황 (선택)" FontSize="11" Foreground="Gray"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="SituationBox"/>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button Content="추가" Click="OnAddSeedClick" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="수정" Click="OnUpdateSeedClick" Padding="10,3" Margin="0,0,4,0"/>
                <Button Content="삭제" Click="OnDeleteSeedClick" Padding="10,3"/>
                <TextBlock Text="상황 설명이 없으면 대사 본문 자체로 매칭됩니다 (C 모드)"
                           FontSize="11" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 3. 안내 -->
        <TextBlock Grid.Row="3" Margin="0,12,0,0" FontSize="11" Foreground="Gray" TextWrapping="Wrap"
                   Text="저장하면 새 씨앗 대사의 임베딩이 자동 계산됩니다. 처음 저장 시 다소 시간이 걸릴 수 있어요."/>

        <!-- 4. 저장/취소 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="SaveButton" Content="저장" Width="80" Click="OnSaveClick" Padding="8,4" Margin="0,0,8,0"/>
            <Button Content="취소" Width="80" Click="OnCancelClick" Padding="8,4"/>
        </StackPanel>
    </Grid>
</Window>
