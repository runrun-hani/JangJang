<UserControl x:Class="JangJang.Views.PetRenderer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center">
        <!-- Speech bubble — softer design with subtle shadow -->
        <Border HorizontalAlignment="Center"
                Background="White" CornerRadius="10"
                Padding="10,5" Margin="0,0,0,6"
                BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="8" Opacity="0.10" Color="Black"/>
            </Border.Effect>
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11" FontWeight="SemiBold"
                       TextAlignment="Center" Foreground="#1E293B"/>
        </Border>

        <!-- Scale wrapper for angry growth -->
        <Grid x:Name="GrowWrapper" HorizontalAlignment="Center" Margin="0,0,0,6">
            <!-- Shake + image/overlay -->
            <Grid x:Name="PetBody" Width="120" Height="120">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="ShakeTransform" X="0"/>
                </Grid.RenderTransform>

                <Image Source="{Binding PetImageSource}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>

                <Rectangle x:Name="ColorOverlay" Opacity="0">
                    <Rectangle.OpacityMask>
                        <ImageBrush ImageSource="{Binding PetImageSource}"
                                    Stretch="Uniform"/>
                    </Rectangle.OpacityMask>
                </Rectangle>
            </Grid>
        </Grid>

        <!-- Work timer — refined pill with monospace font -->
        <Border HorizontalAlignment="Center"
                Background="#CC1E293B" CornerRadius="6"
                Padding="8,3">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <TextBlock x:Name="WorkTimeBlock"
                       Text="{Binding WorkTimeText}"
                       FontSize="28" Foreground="#BBFFFFFF"
                       FontFamily="Consolas"
                       TextAlignment="Center"/>
        </Border>
    </StackPanel>
</UserControl>
