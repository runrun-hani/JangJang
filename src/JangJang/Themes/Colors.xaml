<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════
         Tier 1 — Primitive Colors
         Reference: ui-ux-pro-max-skill/primitive-tokens.md
         ═══════════════════════════════════════════════════════════ -->

    <!-- Slate (neutral gray with cool undertone) -->
    <Color x:Key="Slate50">#F8FAFC</Color>
    <Color x:Key="Slate100">#F1F5F9</Color>
    <Color x:Key="Slate200">#E2E8F0</Color>
    <Color x:Key="Slate300">#CBD5E1</Color>
    <Color x:Key="Slate400">#94A3B8</Color>
    <Color x:Key="Slate500">#64748B</Color>
    <Color x:Key="Slate600">#475569</Color>
    <Color x:Key="Slate700">#334155</Color>
    <Color x:Key="Slate800">#1E293B</Color>
    <Color x:Key="Slate900">#0F172A</Color>

    <!-- Indigo (primary) -->
    <Color x:Key="Indigo50">#EEF2FF</Color>
    <Color x:Key="Indigo100">#E0E7FF</Color>
    <Color x:Key="Indigo200">#C7D2FE</Color>
    <Color x:Key="Indigo500">#6366F1</Color>
    <Color x:Key="Indigo600">#4F46E5</Color>
    <Color x:Key="Indigo700">#4338CA</Color>

    <!-- Red (error / destructive) -->
    <Color x:Key="Red50">#FEF2F2</Color>
    <Color x:Key="Red500">#EF4444</Color>
    <Color x:Key="Red600">#DC2626</Color>

    <!-- Green (success) -->
    <Color x:Key="Green50">#F0FDF4</Color>
    <Color x:Key="Green500">#22C55E</Color>
    <Color x:Key="Green600">#16A34A</Color>

    <!-- Amber (warning / accent) -->
    <Color x:Key="Amber50">#FFFBEB</Color>
    <Color x:Key="Amber500">#F59E0B</Color>
    <Color x:Key="Amber700">#B45309</Color>
    <Color x:Key="Amber900">#78350F</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- ═══════════════════════════════════════════════════════════
         Tier 2 — Semantic Brushes
         Reference: ui-ux-pro-max-skill/semantic-tokens.md
         ═══════════════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="BackgroundBrush"       Color="{StaticResource Slate50}"/>
    <SolidColorBrush x:Key="SurfaceBrush"           Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="MutedBrush"             Color="{StaticResource Slate100}"/>
    <SolidColorBrush x:Key="MutedDarkerBrush"       Color="{StaticResource Slate200}"/>

    <!-- Primary -->
    <SolidColorBrush x:Key="PrimaryBrush"           Color="{StaticResource Indigo500}"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush"      Color="{StaticResource Indigo600}"/>
    <SolidColorBrush x:Key="PrimaryActiveBrush"     Color="{StaticResource Indigo700}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush"      Color="{StaticResource Indigo50}"/>
    <SolidColorBrush x:Key="PrimarySubtleBrush"     Color="{StaticResource Indigo100}"/>
    <SolidColorBrush x:Key="PrimaryForegroundBrush" Color="{StaticResource White}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextBrush"              Color="{StaticResource Slate800}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"     Color="{StaticResource Slate500}"/>
    <SolidColorBrush x:Key="TextMutedBrush"         Color="{StaticResource Slate400}"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush"     Color="{StaticResource White}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush"            Color="{StaticResource Slate200}"/>
    <SolidColorBrush x:Key="BorderStrongBrush"      Color="{StaticResource Slate300}"/>
    <SolidColorBrush x:Key="BorderFocusBrush"       Color="{StaticResource Indigo500}"/>

    <!-- Functional -->
    <SolidColorBrush x:Key="ErrorBrush"             Color="{StaticResource Red500}"/>
    <SolidColorBrush x:Key="ErrorLightBrush"        Color="{StaticResource Red50}"/>
    <SolidColorBrush x:Key="SuccessBrush"           Color="{StaticResource Green500}"/>
    <SolidColorBrush x:Key="SuccessLightBrush"      Color="{StaticResource Green50}"/>
    <SolidColorBrush x:Key="WarningBrush"           Color="{StaticResource Amber500}"/>
    <SolidColorBrush x:Key="WarningLightBrush"      Color="{StaticResource Amber50}"/>
    <SolidColorBrush x:Key="WarningTextBrush"       Color="{StaticResource Amber900}"/>

</ResourceDictionary>
